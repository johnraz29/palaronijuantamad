<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Online Sabong</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #1a1a1a; color: white; }

        /* VIDEO CONTAINER SETUP */
        .video-wrapper {
            position: relative;
            padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
            height: 0;
            overflow: hidden;
            background: #000;
            border: 2px solid #333;
            border-radius: 8px;
        }

        /* ITO ANG SHIELD: Haharang sa click para bawal i-pause */
        .video-shield {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 85%; /* 85% para ma-click pa rin ang volume sa ilalim */
            z-index: 10;
            background: rgba(0,0,0,0); /* Transparent layer */
            cursor: default;
        }

        .video-wrapper iframe, .video-placeholder {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        .video-placeholder {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            background: radial-gradient(circle, #333, #000);
            z-index: 11; /* Dapat mas mataas sa shield kapag offline */
        }

        /* UI STYLES */
        .bet-card {
            background-color: #262626;
            border: none;
            border-radius: 15px;
            padding: 20px;
        }
        .btn-meron { background-color: #d9534f; border: none; font-weight: bold; font-size: 1.5rem; padding: 15px; }
        .btn-meron:hover { background-color: #c9302c; }
        .btn-wala { background-color: #0275d8; border: none; font-weight: bold; font-size: 1.5rem; padding: 15px; }
        .btn-wala:hover { background-color: #025aa5; }
        .balance-display { font-size: 1.2rem; color: #ffc107; text-align: center; margin-bottom: 15px; }
        .alert-custom { margin-top: 10px; border-radius: 10px; }
    </style>
</head>

<body>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="text-center mb-3 text-warning">🔴 LIVE SABONG ARENA</h2>
            
            <div class="video-wrapper mb-4">
                <% if (videoStatus === 'playing' && streamUrl) { %>
                    <div class="video-shield"></div> 
                    <iframe src="<%= streamUrl %>" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                <% } else { %>
                    <div class="video-placeholder text-center">
                        <div class="spinner-grow text-danger" role="status"></div>
                        <h4 class="mt-3">LIVE STREAM IS CURRENTLY STOPPED</h4>
                        <p class="text-muted">Please wait for the next fight to start.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="bet-card shadow shadow-lg">
    <div class="balance-display">
        <strong>My Balance: ₱<%= user.balance.toLocaleString(undefined, {minimumFractionDigits: 2}) %></strong>
    </div>

    <% if (messages.success) { %>
        <div class="alert alert-success alert-custom small"><%= messages.success %></div>
    <% } %>
    <% if (messages.error) { %>
        <div class="alert alert-danger alert-custom small"><%= messages.error %></div>
    <% } %>

    <form id="betForm" class="mt-3">
        <div class="mb-4">
            <label class="form-label text-light">Enter Amount to Bet:</label>
            <div class="input-group">
                <span class="input-group-text bg-dark text-white border-secondary">₱</span>
                <input type="number" id="betAmount" name="amount" class="form-control bg-dark text-white border-secondary" placeholder="0.00" min="1" required>
            </div>
        </div>

        <div class="d-grid gap-3">
            <button type="button" onclick="submitBet('Meron')" class="btn btn-meron text-white shadow">
                MERON
            </button>
            <div class="text-center text-muted fw-bold">VS</div>
            <button type="button" onclick="submitBet('Wala')" class="btn btn-wala text-white shadow">
                WALA
            </button>
        </div>
    </form>

    <div id="betMessage" class="mt-2"></div>

    <div class="mt-4 small text-muted">
        <p class="mb-1 text-center">* Admin takes 20% commission on the total pot.</p>
        <p class="text-center">* Winners share 80% of the pool proportionally.</p>
    </div>
</div>

   <div class="row mt-5">
    <div class="col-12">
        <div class="table-responsive bg-dark p-0 rounded-4 shadow-lg border border-secondary">
            <div class="p-3 border-bottom border-secondary d-flex justify-content-between align-items-center">
                <h5 class="text-warning m-0">
                    <i class="fas fa-history"></i> My Betting History
                </h5>
                <span class="badge bg-danger px-3 py-2" style="animation: blink 1s infinite;">LIVE DATA</span>
            </div>
            
            <table class="table table-dark table-hover mt-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-3">Time</th>
                        <th>Choice</th>
                        <th>Bet Amount</th>
                        <th>Status</th>
                        <th class="pe-3">Payout</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="small text-muted text-center">
                        <td colspan="5" class="py-4">Refresh page to see updated bet history.</td>
                    </tr>
                </tbody>
            </table>
        </div>
        </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function submitBet(choice) {
    const amount = document.getElementById('betAmount').value;
    const messageDiv = document.getElementById('betMessage');

    if (!amount || amount <= 0) {
        messageDiv.innerHTML = '<div class="alert alert-danger small">Enter amount first!</div>';
        return;
    }

    // Optional: I-disable ang buttons habang nag-o-on progress ang bet
    messageDiv.innerHTML = '<div class="alert alert-info small">Placing bet...</div>';

    try {
        const response = await fetch('/bet/sabong', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ amount, choice })
        });

        const result = await response.json();

        if (response.ok) {
            messageDiv.innerHTML = `<div class="alert alert-success small">✅ ${result.message}</div>`;
            document.getElementById('betAmount').value = ''; // Clear input
        } else {
            messageDiv.innerHTML = `<div class="alert alert-danger small">❌ ${result.error}</div>`;
        }
    } catch (error) {
        messageDiv.innerHTML = '<div class="alert alert-danger small">Network Error.</div>';
    }
}
</script>
</body>
</html>