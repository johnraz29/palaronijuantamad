<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Controller Panel</title>
<link rel="stylesheet" href="/dashboard.css">

<style>
.container {
    max-width: 1000px;
    margin: auto;
    padding: 20px;
}

.card {
    background: rgba(0,0,0,0.7);
    border: 1px solid #00ff7f;
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 25px;
}

.card h2 {
    color: #00ff7f;
    margin-bottom: 15px;
}

.video-frame {
    width: 100%;
    height: 300px;
    border-radius: 10px;
    margin-bottom: 15px;
}

/* BUTTONS */
button {
    padding: 12px 25px;
    margin: 5px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    font-size: 1em;
}

.btn-win {
    background: #00ff7f;
    color: #000;
}

.btn-lose {
    background: #ff4444;
    color: #fff;
}

/* INPUTS */
.number-grid {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
}

.number-grid input {
    width: 60px;
    height: 60px;
    font-size: 1.5em;
    text-align: center;
    border-radius: 10px;
    border: 1px solid #00ff7f;
    background: #000;
    color: #fff;
}

.twodigit input {
    width: 70px;
    height: 70px;
    font-size: 1.5em;
}
</style>
</head>

<body>

<div class="container">

<h1>🎮 Controller Panel</h1>

<!-- 🐔 SABONG -->
<div class="card">
    <h2>🐔 Online Sabong</h2>

    <!-- ✅ LIVE VIDEO (FIXED) -->
    <% if (streamUrl) { %>
        <iframe class="video-frame"
            src="<%= streamUrl %>"
            frameborder="0"
            allow="autoplay; encrypted-media"
            allowfullscreen>
        </iframe>
    <% } else { %>
        <p>No live stream set.</p>
    <% } %>

    <form action="/controller/sabong-result" method="POST">
        <button name="winner" value="MERON" class="btn-win">MERON</button>
        <button name="winner" value="WALA" class="btn-lose">WALA</button>
    </form>
</div>

<!-- 🎯 6-DIGIT DRAW -->
<div class="card">
    <h2>🎯 6-Digit Draw</h2>

    <form action="/controller/draw-result" method="POST" onsubmit="combineNumbers()">
        <input type="hidden" name="game_type" value="lotto">
        <input type="hidden" name="numbers" id="finalNumbers">

        <div class="number-grid">
            <input type="number" min="1" max="60" required>
            <input type="number" min="1" max="60" required>
            <input type="number" min="1" max="60" required>
            <input type="number" min="1" max="60" required>
            <input type="number" min="1" max="60" required>
            <input type="number" min="1" max="60" required>
        </div>

        <br>
        <button type="submit" class="btn-win">DECLARE RESULT</button>
    </form>
</div>

<!-- 🔢 TWO DIGIT -->
<div class="card">
    <h2>🔢 Two Digit Ball</h2>

    <form action="/controller/draw-result" method="POST">
        <input type="hidden" name="game_type" value="twodigit">

        <div class="number-grid twodigit">
            <input type="number" name="num1" min="1" max="60" required>
            <input type="number" name="num2" min="1" max="60" required>
        </div>

        <br>
        <button type="submit" class="btn-win">DECLARE RESULT</button>
    </form>
</div>

</div>

<script>
function combineNumbers() {
    const inputs = document.querySelectorAll('.number-grid input:not([name])');
    let values = [];

    inputs.forEach(input => {
        values.push(input.value);
    });

    document.getElementById('finalNumbers').value = values.join(',');
}
</script>

</body>
</html>