<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Top Up</title>
<link rel="stylesheet" href="/topup.css" />
</head>

<body>

<div class="background"></div>

<header class="top-header">
    <div class="logo">
        <img src="/images/logo.png" alt="Logo">
        <h1>Wallet Top-Up</h1>
    </div>
</header>

<main class="container">

<div class="topup-card">

<h2>Top-up Balance</h2>

<p class="description">
Enter the amount you want to top up using <strong>GCash via PayMongo</strong>.
Minimum top-up is ₱50.
</p>

<form action="/paymongo/gcash" method="POST">

  <div class="form-group">
    <label>Amount (PHP)</label>
    <input 
      name="amount"
      id="amount"
      type="number"
      min="50"
      max="100000"
      step="1"
      placeholder="Enter amount (Minimum ₱50)"
      required>
    <small>Minimum ₱50 • Maximum ₱100,000</small>
  </div>

  <button type="submit" class="topup-btn">
    Pay with GCash
  </button>

</form>

</div>

</main>

<script>
const amountInput = document.getElementById("amount");

amountInput.addEventListener("input", function () {

    // remove non-numbers
    this.value = this.value.replace(/[^0-9]/g, "");

    // enforce minimum
    if (this.value && this.value < 50) {
        this.setCustomValidity("Minimum amount is ₱50");
    } else {
        this.setCustomValidity("");
    }

    // enforce max
    if (this.value > 100000) {
        this.value = 100000;
    }

});
</script>

</body>
</html>